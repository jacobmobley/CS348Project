# Backend app settings
DB_USER=app
DB_PASSWORD=app_pw
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
# Optional: use this instead of DB_* values
# DATABASE_URL=postgresql+psycopg://app:app_pw@localhost:5432/app_db

# Backend CORS settings (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Postgres container settings (used by backend/db/init/docker-compose.yml)
POSTGRES_USER=app
POSTGRES_PASSWORD=app_pw
POSTGRES_DB=app_db
POSTGRES_PORT=5432
